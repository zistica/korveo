# Keep build context small. Without this, Docker uploads node_modules, venvs,
# build artifacts, etc. — gigabytes of garbage that slow every build.
**/node_modules
**/.venv
**/__pycache__
**/.pytest_cache
**/.next
**/dist
**/build
**/*.egg-info
**/.coverage
**/coverage

# Editor / OS junk
**/.DS_Store
**/.idea
**/.vscode
**/*.swp

# Local data / logs
**/data/
**/*.log

# Git
.git
.gitignore
.github

# Docs not needed at runtime
docs/
*.md
!packages/sdk-python/README.md
