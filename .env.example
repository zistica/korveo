# Copy to .env and edit. docker compose reads .env automatically.
# Mode 600 recommended once it contains real secrets.

# Retention (defaults: 90 days, 50000 traces)
KORVEO_RETENTION_DAYS=90
KORVEO_RETENTION_TRACES=50000

# Default project tag for ingested traces
KORVEO_PROJECT=default

# Skip auto-installing the OWASP LLM Top 10 starter pack
KORVEO_DISABLE_STARTER_PACK=

# --- Webhook / notification config (Slice 4) ---
# SMTP server for email notifications. Required only if you create an
# email-kind webhook via /v1/firewall/webhooks. Slack / Discord /
# PagerDuty webhooks don't need any of these.
KORVEO_SMTP_HOST=
KORVEO_SMTP_PORT=587
KORVEO_SMTP_USERNAME=
KORVEO_SMTP_PASSWORD=
KORVEO_SMTP_FROM=korveo-firewall@localhost
KORVEO_SMTP_USE_TLS=true

# --- Auth ---
# When set, requires Authorization: Bearer <token> on all /v1/* calls.
# When UNSET, the API is open to loopback only — non-loopback clients
# get 403 (so an instance bound to 0.0.0.0 can't leak traces).
# KORVEO_API_TOKEN=
# Accept the risk of serving the API to non-loopback clients with no
# token (trusted private network, or auth terminated at a proxy):
# KORVEO_ALLOW_INSECURE=1
# When set, dashboard requires login at /login
# KORVEO_DASHBOARD_PASSWORD=
